# Synapse 本地开发凭据模板
# 用法:cp .env.example .env,再把下面的占位符改成你自己的本地口令。
# 重要:.env 已被 .gitignore 屏蔽,严禁提交真实口令。这里只放占位符。

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=change_me_mysql

# ---- Redis ----
REDIS_PASSWORD=change_me_redis

# ---- RabbitMQ ----
RABBITMQ_USER=synapse
RABBITMQ_PASSWORD=change_me_rabbitmq

# ---- MinIO(S3 兼容对象存储)----
MINIO_ROOT_USER=synapse
MINIO_ROOT_PASSWORD=change_me_minio_at_least_8_chars

# ---- Nacos 鉴权(2.x 开启鉴权所需)----
# NACOS_AUTH_TOKEN 需为 Base64 字符串,长度足够(建议 >= 32 字节原文再 Base64)
NACOS_AUTH_TOKEN=VGhpc0lzQVNhbXBsZURldlRva2VuUGxlYXNlQ2hhbmdlTWU=
NACOS_AUTH_IDENTITY_KEY=synapse-identity
NACOS_AUTH_IDENTITY_VALUE=change_me_nacos_identity

# ---- Sentinel 控制台 ----
SENTINEL_USER=synapse
SENTINEL_PASSWORD=change_me_sentinel
