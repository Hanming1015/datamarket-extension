    {
      "name": "[手动] createDataset for upload",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "pm.test(\"业务码 200\", () => pm.expect(body.code).to.eql(200));",
              "pm.collectionVariables.set(\"dsId2\", body.data.id);",
              "console.log(\"上传用 dsId2 = \" + body.data.id);"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"CSV Upload Dataset\",\r\n  \"category\": \"hr\"\r\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/datasets",
          "host": ["{{baseUrl}}"],
          "path": ["api", "datasets"]
        }
