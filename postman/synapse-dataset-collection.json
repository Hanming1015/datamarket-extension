    {
      "name": "[手动] uploadCsv (选择本地 .csv)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"HTTP 200\", () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test(\"业务码 200\", () => pm.expect(body.code).to.eql(200));",
              "pm.test(\"parseStatus=UPLOADED\", () => pm.expect(body.data.parseStatus).to.eql(\"UPLOADED\"));"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": [], "description": "在 Postman 里点这里选一个本地 .csv 文件(如 name,age,email 表头)" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/datasets/{{dsId2}}/file",
          "host": ["{{baseUrl}}"],
          "path": ["api", "datasets", "{{dsId2}}", "file"]
        },
        "description": "multipart 上传 CSV。字段名 file,需手动选择本地文件;自动 Runner 无文件会失败,属正常。"
      },
      "response": []
    },
    {
      "name": "[手动] parse-status (轮询解析)",
      "protocolProfileBehavior": { "disableBodyPruning": true },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"HTTP 200\", () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test(\"业务码 200\", () => pm.expect(body.code).to.eql(200));",
              "console.log(\"parseStatus = \" + body.data.parseStatus + \", recordCount = \" + body.data.recordCount);",
              "pm.test(\"状态在预期集合内\", () => pm.expect([\"UPLOADED\",\"PARSING\",\"READY\",\"FAILED\"]).to.include(body.data.parseStatus));"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
        "method": "GET",
        "header": [],
        "url": {
